# ─── Gravity Academy — environment variables ──────────────────────────────
# Copy to `.env` and fill in. Never commit `.env`.

# ── Lead email (server-side, used by /api/enquiry) ──
# Resend API key (https://resend.com). Leave blank in dev to test the form flow
# without actually sending (submissions succeed but no email goes out).
RESEND_API_KEY=
# Verified sender (must match a domain verified in Resend).
FROM_EMAIL="Gravity Academy <noreply@gogravity.in>"
# Where admissions enquiries are delivered.
ADMISSIONS_EMAIL=info@gogravity.in

# ── Optional: also forward each lead to a Sheet / CRM webhook ──
# (Google Apps Script / Zapier / Make endpoint that accepts a JSON POST.)
LEADS_WEBHOOK=

# ── WordPress / WooCommerce catalog (the separate shop surface, §2 & §11) ──
# Either a path on the same domain (reverse-proxy) or a subdomain.
# Exposed to the browser, so it MUST be prefixed PUBLIC_.
PUBLIC_WP_SHOP_BASE=https://www.gogravity.in/shop

# Feature flag (§2.3): "true" fetches live program data from the Woo Store API,
# falling back to local data on failure. Leave "false" until the shop is live.
PUBLIC_USE_WP_API=false
