---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import FacultyCard from '../components/FacultyCard.astro';
import CTABand from '../components/CTABand.astro';
import { faculty } from '../data/faculty';
import { educationalOrganizationLd } from '../data/jsonld';
---
<BaseLayout
  title="Faculty"
  description="Meet the mentors behind Gravity Academy — experienced subject specialists who teach concept-first and know each student by name."
  path="/faculty"
  jsonld={[educationalOrganizationLd]}
>
  <PageHeader
    eyebrow="Faculty"
    title="Mentors, not just teachers"
    intro="Every mentor here is a subject specialist who teaches from first principles and tracks each student personally. This is what mentorship-driven coaching actually looks like."
  />

  <Section tone="paper">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {faculty.map((m) => (
        <div data-reveal><FacultyCard member={m} /></div>
      ))}
    </div>
  </Section>

  <CTABand title="Meet your child's mentor." text="Book a free demo and sit in on a real class with our faculty." />
</BaseLayout>
