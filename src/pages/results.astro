---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import TopperCard from '../components/TopperCard.astro';
import CTABand from '../components/CTABand.astro';
import Icon from '../components/Icon.astro';
import { toppers, boardFilters, gradeFilters } from '../data/toppers';
import { educationalOrganizationLd } from '../data/jsonld';

const founderTrack = [
  { icon: 'medal', stat: 'AIR 1', label: 'Mentored — NEET' },
  { icon: 'award', stat: 'AIR 5', label: 'Mentored — AIIMS' },
  { icon: 'users', stat: 'Many', label: 'State & national rank holders guided' },
  { icon: 'clock', stat: '14+', label: 'Years of teaching experience' },
];
---
<BaseLayout
  title="Results & Toppers"
  description="Gravity Academy's first-year results — board and subject toppers across CBSE and ICSE — plus our founder's national track record mentoring AIR 1 NEET and AIR 5 AIIMS."
  path="/results"
  jsonld={[educationalOrganizationLd]}
>
  <PageHeader
    eyebrow="Results"
    title="Our first year. Their proud victory."
    intro="Concept-first teaching, small batches and relentless practice — here's what our very first cohort achieved."
  />

  <!-- Founder track record -->
  <Section tone="paper">
    <SectionHead eyebrow="Founder's track record" title="A mentor with a national record" intro="Before Gravity, our founder Ankush Koul mentored some of the country's top rank holders." />
    <div class="mt-10 grid grid-cols-2 gap-4 lg:grid-cols-4">
      {founderTrack.map((f) => (
        <div class="rounded-card border border-mist bg-paper-2 p-6 text-center shadow-soft" data-reveal>
          <span class="mx-auto grid h-12 w-12 place-items-center rounded-full bg-orange/12 text-orange"><Icon name={f.icon} size={26} /></span>
          <p class="mt-4 font-display text-display-md font-bold text-navy">{f.stat}</p>
          <p class="mt-1 text-sm text-slate">{f.label}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Student results grid -->
  <Section tone="paper-2">
    <SectionHead eyebrow="Our students" title="First-year toppers" intro="Real results from our 2025–26 cohort across CBSE and ICSE." />

    <div class="mt-8 flex flex-col gap-5 md:flex-row md:items-center md:justify-between" data-reveal>
      <div role="group" aria-label="Filter by board" class="flex flex-wrap gap-2">
        {boardFilters.map((f, i) => (
          <button
            type="button"
            class="filter-board rounded-full px-4 py-2 text-sm font-semibold ring-1 ring-mist transition-colors data-[active]:bg-navy data-[active]:text-white data-[active]:ring-navy"
            data-value={f}
            data-active={i === 0 ? '' : null}
          >{f}</button>
        ))}
      </div>
      <label class="flex items-center gap-2 text-sm text-slate">
        Class
        <select id="filter-grade" class="rounded-btn border border-slate/35 bg-paper px-3 py-2 text-ink focus:border-navy focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-orange/30">
          {gradeFilters.map((g) => <option value={g}>{g === 'All' ? 'All classes' : g}</option>)}
        </select>
      </label>
    </div>

    <div id="toppers-grid" class="mt-10 grid grid-cols-2 gap-5 md:grid-cols-3 lg:grid-cols-4">
      {toppers.map((t) => <TopperCard topper={t} />)}
    </div>
    <p id="no-results" class="mt-10 hidden rounded-card bg-paper p-8 text-center text-slate">No results match these filters. Try a different board or class.</p>
  </Section>

  <!-- Results poster -->
  <Section tone="paper">
    <div class="grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-center">
      <div data-reveal>
        <SectionHead eyebrow="The full picture" title="Celebrating every achiever" intro="Our first-year results poster — every name here put in the work, and their mentors made sure it counted." />
        <p class="mt-6 rounded-card bg-paper-2 p-5 text-slate ring-1 ring-mist">
          Programs across <strong class="text-navy">6th–10th and 11th–12th</strong> — CBSE, ICSE, State, PU, KCET, JEE and NEET UG.
        </p>
      </div>
      <div class="mx-auto max-w-sm overflow-hidden rounded-card shadow-lift ring-1 ring-mist" data-reveal>
        <img src="/results/results-poster.jpg" alt="Gravity Academy first-year results poster with student scores" width="600" height="850" loading="lazy" decoding="async" class="h-full w-full object-cover" />
      </div>
    </div>
  </Section>

  <CTABand title="Be part of the next topper list." text="Admissions are open. It starts with one free demo class — see how we teach, then decide." />
</BaseLayout>

<script>
  const boardBtns = document.querySelectorAll<HTMLButtonElement>('.filter-board');
  const gradeSel = document.getElementById('filter-grade') as HTMLSelectElement;
  const cards = Array.from(document.querySelectorAll<HTMLElement>('#toppers-grid .topper-card'));
  const empty = document.getElementById('no-results')!;
  let board = 'All';

  const apply = () => {
    const grade = gradeSel.value;
    let shown = 0;
    cards.forEach((card) => {
      const okBoard = board === 'All' || card.dataset.board === board;
      const okGrade = grade === 'All' || card.dataset.grade === grade;
      const show = okBoard && okGrade;
      card.classList.toggle('hidden', !show);
      if (show) shown++;
    });
    empty.classList.toggle('hidden', shown > 0);
  };

  boardBtns.forEach((btn) =>
    btn.addEventListener('click', () => {
      board = btn.dataset.value ?? 'All';
      boardBtns.forEach((b) => b.removeAttribute('data-active'));
      btn.setAttribute('data-active', '');
      apply();
    })
  );
  gradeSel.addEventListener('change', apply);
</script>
