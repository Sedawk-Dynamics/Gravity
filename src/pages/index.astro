---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import Button from '../components/Button.astro';
import OrbitHero from '../components/OrbitHero.astro';
import ProgramCard from '../components/ProgramCard.astro';
import StatCard from '../components/StatCard.astro';
import TopperCard from '../components/TopperCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTABand from '../components/CTABand.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
import { getPrograms } from '../data/programs';
import { toppers } from '../data/toppers';
import { testimonials } from '../data/testimonials';
import { educationalOrganizationLd, localBusinessLd } from '../data/jsonld';

const why = [
  { icon: 'users', title: 'Small batches', text: 'Capped enrolment so every mentor knows each student\'s strengths and gaps.' },
  { icon: 'lightbulb', title: 'Concept-first teaching', text: 'We build understanding from first principles — no rote, no shortcuts.' },
  { icon: 'graduation-cap', title: 'Personalized mentoring', text: 'One-to-one guidance that adapts to how each student learns.' },
  { icon: 'monitor', title: 'Hybrid learning', text: 'Learn your way — offline classroom, online-live, or a hybrid of both.' },
  { icon: 'trending-up', title: 'Parent performance tracking', text: 'Regular tests, PTMs and progress updates so families always know where things stand.' },
];

const programs = await getPrograms();
const featured = programs.filter((p) => ['jee-foundation', 'neet-foundation', 'test-prep', 'olympiads'].includes(p.id));
const homeToppers = toppers.slice(0, 4);

// Real first-year milestones (source: founder's "Milestones of Growth" address).
const stats = [
  { value: 47, suffix: '+', label: 'Students mentored in year one' },
  { value: 720, suffix: '+', label: 'Hours of classroom teaching' },
  { value: 100, suffix: '+', label: 'Hours of doubt-solving sessions' },
  { value: 14, suffix: '+', label: 'Years of founder teaching experience' },
];
---
<BaseLayout
  title="Home"
  description={site.description}
  path="/"
  transparentHeader
  jsonld={[educationalOrganizationLd, localBusinessLd]}
>
  <!-- 1. HERO — the signature -->
  <section class="relative overflow-hidden bg-navy text-white">
    <div class="grid-motif pointer-events-none absolute inset-0 opacity-30"></div>
    <div class="pointer-events-none absolute -right-32 -top-32 h-96 w-96 rounded-full bg-orange/10 blur-3xl"></div>
    <div class="container-x relative grid items-center gap-12 pb-16 pt-32 md:pt-36 lg:grid-cols-[1.05fr_1fr] lg:gap-8 lg:pb-24 lg:pt-40">
      <div class="max-w-xl">
        <p class="eyebrow">Gravity Academy · Bengaluru</p>
        <h1 class="mt-4 font-display text-display-xl text-white">
          Build the concepts that hold everything together.
        </h1>
        <p class="mt-5 max-w-md text-lg leading-relaxed text-mist">
          Concept-first coaching in Bengaluru for Grades 6–12 across CBSE, ICSE and State Board — plus JEE, NEET UG and KCET preparation. Small batches, real mentorship, measurable progress.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/admissions" variant="primary" size="lg" icon="arrow-right">Book a free demo</Button>
          <Button href="/programs" variant="ghost" size="lg" class="!text-white !ring-white/40 hover:!bg-white/10">Explore programs</Button>
        </div>
      </div>

      <div class="orbit-parallax">
        <OrbitHero />
      </div>
    </div>
  </section>

  <!-- 2. TRUST STRIP -->
  <div class="border-y border-mist bg-paper-2">
    <div class="container-x flex flex-wrap items-center justify-center gap-x-8 gap-y-2 py-5 text-center">
      <span class="font-mono text-xs uppercase tracking-[0.18em] text-slate">Aligned with</span>
      {site.boards.map((b) => (
        <span class="font-display text-sm font-semibold text-navy">{b}</span>
      ))}
      <span class="font-display text-sm font-semibold text-navy">JEE · NEET UG · KCET</span>
    </div>
  </div>

  <!-- 3. PROGRAMS GRID -->
  <Section tone="paper">
    <SectionHead
      eyebrow="Programs"
      title="Six tracks, one disciplined ecosystem"
      intro="Each program is built around concept mastery first, then exam technique — so progress compounds instead of cramming."
    />
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {programs.map((p, i) => (
        <div data-reveal style={`--reveal-delay:${(i % 3) * 80}ms`}>
          <ProgramCard program={p} />
        </div>
      ))}
    </div>
  </Section>

  <!-- 4. STATS BAND -->
  <Section tone="navy">
    <div class="grid items-center gap-10 lg:grid-cols-[1fr_1.4fr]">
      <SectionHead
        eyebrow="By the numbers"
        title="Outcomes that earn parent trust"
        intro="Real results from a disciplined, mentorship-driven system."
        tone="dark"
      />
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-2 xl:grid-cols-4">
        {stats.map((s) => (
          <div data-reveal>
            <StatCard value={s.value} suffix={s.suffix} label={s.label} separator={s.separator ?? true} />
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- 5. WHY GRAVITY -->
  <Section tone="paper-2">
    <SectionHead eyebrow="Why Gravity" title="What makes the difference" />
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {why.map((w) => (
        <div class="flex gap-4 rounded-card border border-mist bg-paper p-6 shadow-soft" data-reveal>
          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-btn bg-mist text-navy">
            <Icon name={w.icon} size={22} />
          </span>
          <div>
            <h3 class="font-display text-display-sm text-navy">{w.title}</h3>
            <p class="mt-1.5 text-slate">{w.text}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- 5b. INSIDE GRAVITY — campus gallery -->
  <Section tone="paper">
    <SectionHead eyebrow="Inside Gravity" title="Where the work happens" intro="From our annual Aarambh event to parent orientations and packed classrooms — a look at the Gravity community in action." />
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { src: '/gallery/students-founder.jpg', alt: 'Gravity Academy students with the founder at the annual event', span: 'lg:row-span-2 lg:h-full' },
        { src: '/founder/aarambh.jpg', alt: 'Founder Ankush Koul addressing the Aarambh 2026 event' },
        { src: '/gallery/parent-orientation.jpg', alt: 'Parents at a Gravity Academy orientation' },
      ].map((img, i) => (
        <div
          class:list={['overflow-hidden rounded-card ring-1 ring-mist', img.span]}
          data-reveal
          style={`--reveal-delay:${i * 80}ms`}
        >
          <img
            src={img.src}
            alt={img.alt}
            width="640"
            height="480"
            loading="lazy"
            decoding="async"
            class="h-full min-h-[220px] w-full object-cover transition-transform duration-500 hover:scale-[1.04]"
          />
        </div>
      ))}
    </div>
  </Section>

  <!-- 6. FEATURED BATCHES -->
  <Section tone="paper-2">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <SectionHead eyebrow="Featured batches" title="Popular tracks enrolling now" class="!max-w-xl" />
      <Button href="/programs" variant="ghost" icon="arrow-right" class="hidden sm:inline-flex">All programs</Button>
    </div>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {featured.map((p) => (
        <a
          href={`/programs/${p.slug}`}
          class="group flex flex-col rounded-card border border-mist bg-paper-2 p-6 transition-all duration-300 ease-fall hover:-translate-y-1 hover:shadow-lift"
          data-reveal
        >
          <span class="grid h-11 w-11 place-items-center rounded-btn bg-navy text-white transition-colors group-hover:bg-orange group-hover:text-navy">
            <Icon name={p.icon} size={22} />
          </span>
          <h3 class="mt-4 font-display text-display-sm text-navy">{p.name}</h3>
          <p class="mt-1.5 flex-1 text-sm text-slate">{p.tagline}</p>
          <span class="mt-4 inline-flex items-center gap-1.5 font-display text-sm font-semibold text-navy group-hover:text-orange">
            View program <Icon name="arrow-right" size={16} />
          </span>
        </a>
      ))}
    </div>
  </Section>

  <!-- 7. RESULTS HIGHLIGHT -->
  <Section tone="paper">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <SectionHead eyebrow="Results" title="Students who went further" class="!max-w-xl" />
      <Button href="/results" variant="ghost" icon="arrow-right" class="hidden sm:inline-flex">All results</Button>
    </div>
    <div class="mt-10 grid grid-cols-2 gap-5 lg:grid-cols-4">
      {homeToppers.map((t) => (
        <div data-reveal><TopperCard topper={t} /></div>
      ))}
    </div>
  </Section>

  <!-- 8. TESTIMONIALS -->
  <Section tone="paper-2">
    <SectionHead eyebrow="In their words" title="What parents and students say" />
    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {testimonials.map((t) => (
        <div data-reveal><TestimonialCard testimonial={t} /></div>
      ))}
    </div>
  </Section>

  <!-- 9. CTA BAND -->
  <CTABand />
</BaseLayout>

<script>
  // Gentle scroll parallax for the hero orbit. Respects reduced motion.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const el = document.querySelector<HTMLElement>('.orbit-parallax');
  if (el && !reduce) {
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      if (y < 900) el.style.transform = `translateY(${y * 0.06}px)`;
      ticking = false;
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
  }
</script>
