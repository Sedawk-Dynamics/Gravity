---
import { site } from '../data/site';

/**
 * Official Gravity Academy logo (client-supplied lockup: "Orbit Gravity Academy"
 * with the Foundation/Test-Prep tagline). Two variants:
 *  - dark  → navy logo, for LIGHT backgrounds (/logo/gravity.svg)
 *  - light → white logo, for DARK/navy backgrounds (/logo/gravity-white.svg,
 *            generated from the source SVG: navy→white, pill→transparent, orange kept)
 */
interface Props {
  variant?: 'dark' | 'light';
  class?: string;
}
const { variant = 'dark', class: className = '' } = Astro.props;
const src = variant === 'light' ? '/logo/gravity-white.svg' : '/logo/gravity.svg';
---
<img
  src={src}
  alt={`${site.name} logo`}
  width="483"
  height="171"
  class:list={['w-auto', className]}
  loading="eager"
  decoding="async"
/>
