---
import Icon from './Icon.astro';

/**
 * Homepage hero: three approved, client-supplied banner designs
 * (Foundation VI–X · JEE Foundation · NEET Foundation). Each banner already
 * carries its own headline, tagline and artwork, so we only overlay the two
 * CTAs and the slider controls — kept in a bar BELOW the image and on the image
 * EDGES, so buttons and slider controls never overlap.
 * Auto-rotates (pauses on hover/focus); reduced-motion shows the first slide.
 */
// Note: files live in /hero (NOT /banners) — folder names containing "banner"
// are blocked by many browser ad-blockers and by some dev servers.
const banners = [
  { jpg: '/hero/foundation.jpg', webp: '/hero/foundation.webp', alt: 'Foundation (VI–X) — where strong foundations create future toppers', href: '/programs/foundation', cta: 'Explore Foundation' },
  { jpg: '/hero/jee.jpg', webp: '/hero/jee.webp', alt: 'JEE Foundation — build a strong foundation for JEE success', href: '/programs/jee-foundation', cta: 'Explore JEE' },
  { jpg: '/hero/neet.jpg', webp: '/hero/neet.webp', alt: 'NEET Foundation — build a strong foundation for medical success', href: '/programs/neet-foundation', cta: 'Explore NEET' },
];
---
<section id="hero-banners" class="bg-navy" aria-roledescription="carousel" aria-label="Programs">
  <!-- Full-bleed hero banner: edge-to-edge, no radius, natural 16:9 so the
       COMPLETE banner image is always shown with nothing cropped. -->
  <div class="relative aspect-[16/9] w-full overflow-hidden bg-navy">
    {banners.map((b, i) => (
      <picture class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-700 ease-fall data-[active]:opacity-100 data-[active]:z-[1]" data-active={i === 0 ? '' : null} aria-hidden={i === 0 ? 'false' : 'true'}>
        <source srcset={b.webp} type="image/webp" />
        <img src={b.jpg} alt={b.alt} width="2000" height="1125" loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} decoding="async" class="h-full w-full object-cover object-center" />
      </picture>
    ))}

    <!-- Prev / next arrows on the image edges (vertically centred) -->
    <button id="hero-prev" type="button" class="absolute left-3 top-1/2 z-10 hidden h-11 w-11 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-navy shadow-soft ring-1 ring-navy/10 transition-colors hover:bg-white focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-orange/50 sm:grid lg:left-5" aria-label="Previous slide">
      <Icon name="chevron-right" size={22} class="rotate-180" />
    </button>
    <button id="hero-next" type="button" class="absolute right-3 top-1/2 z-10 hidden h-11 w-11 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-navy shadow-soft ring-1 ring-navy/10 transition-colors hover:bg-white focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-orange/50 sm:grid lg:right-5" aria-label="Next slide">
      <Icon name="chevron-right" size={22} />
    </button>
  </div>

  <!-- CTAs + dots on a clean light bar (contrasts with the navy banner). -->
  <div class="border-b border-mist bg-paper">
    <div class="container-x flex flex-wrap items-center justify-center gap-x-5 gap-y-3 py-4">
      <button type="button" data-open-demo class="group inline-flex items-center justify-center gap-2 rounded-btn bg-orange px-6 py-3 font-display font-semibold text-navy shadow-soft transition-all duration-200 ease-fall hover:bg-navy hover:text-white focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-orange/45">
        Book a free demo
        <Icon name="arrow-right" size={18} class="transition-transform group-hover:translate-x-0.5" />
      </button>
      <a id="hero-explore" href={banners[0].href} class="inline-flex items-center justify-center gap-2 rounded-btn px-6 py-3 font-display font-semibold text-navy ring-1 ring-inset ring-navy/25 transition-colors hover:bg-navy hover:text-white">
        {banners[0].cta}
      </a>
      <div class="flex gap-2 sm:ml-2" role="tablist" aria-label="Choose slide">
        {banners.map((b, i) => (
          <button type="button" class="hero-dot h-2.5 w-2.5 rounded-full bg-slate/40 transition-all duration-300 data-[active]:w-8 data-[active]:bg-orange" data-index={i} data-active={i === 0 ? '' : null} role="tab" aria-label={b.cta} aria-selected={i === 0 ? 'true' : 'false'}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.getElementById('hero-banners');
  if (root) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.hero-slide'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('.hero-dot'));
    const explore = document.getElementById('hero-explore') as HTMLAnchorElement | null;
    const meta = [
      { href: '/programs/foundation', cta: 'Explore Foundation' },
      { href: '/programs/jee-foundation', cta: 'Explore JEE' },
      { href: '/programs/neet-foundation', cta: 'Explore NEET' },
    ];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let i = 0;
    let timer: number | undefined;

    const show = (n: number) => {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, k) => { s.toggleAttribute('data-active', k === i); s.setAttribute('aria-hidden', k === i ? 'false' : 'true'); });
      dots.forEach((d, k) => { d.toggleAttribute('data-active', k === i); d.setAttribute('aria-selected', k === i ? 'true' : 'false'); });
      if (explore && meta[i]) { explore.href = meta[i].href; explore.textContent = meta[i].cta; }
    };
    const next = () => show(i + 1);
    const start = () => { if (!reduce) timer = window.setInterval(next, 5500); };
    const stop = () => { if (timer) window.clearInterval(timer); };
    const restart = () => { stop(); start(); };

    dots.forEach((d) => d.addEventListener('click', () => { show(Number(d.dataset.index)); restart(); }));
    document.getElementById('hero-next')?.addEventListener('click', () => { next(); restart(); });
    document.getElementById('hero-prev')?.addEventListener('click', () => { show(i - 1); restart(); });
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', start);
    start();
  }
</script>
