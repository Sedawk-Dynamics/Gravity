---
import type { Faculty } from '../data/faculty';

interface Props {
  member: Faculty;
}
const { member } = Astro.props;
---
<article class="group flex flex-col overflow-hidden rounded-card border border-mist bg-paper shadow-soft transition-all duration-300 ease-fall hover:-translate-y-1 hover:shadow-lift">
  <div class="aspect-square overflow-hidden bg-mist">
    <img
      src={member.photo}
      alt={`${member.name}, ${member.subject} faculty`}
      width="360"
      height="360"
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
    />
  </div>
  <div class="p-5">
    <p class="eyebrow !text-slate">{member.subject}</p>
    <h3 class="mt-1 font-display text-display-sm text-navy">{member.name}</h3>
    <p class="mt-1.5 text-sm text-slate">{member.credential}</p>
  </div>
</article>
