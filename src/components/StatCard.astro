---
import AnimatedCounter from './AnimatedCounter.astro';

interface Props {
  value: number;
  label: string;
  prefix?: string;
  suffix?: string;
  separator?: boolean;
}
const { value, label, prefix = '', suffix = '', separator = true } = Astro.props;
---
<div class="flex flex-col gap-1 rounded-card bg-white/5 px-6 py-7 ring-1 ring-white/10">
  <span class="font-display text-display-md font-bold text-orange">
    <AnimatedCounter value={value} prefix={prefix} suffix={suffix} separator={separator} />
  </span>
  <span class="text-sm leading-snug text-mist">{label}</span>
</div>
