---
/**
 * Inline SVG icon set (Lucide line icons, MIT). Inlined rather than pulled from a
 * package so there's zero runtime/build dependency and the stroke style stays
 * consistent with the "scientific instrument" art direction. `currentColor` means
 * colour is controlled by the parent's text colour.
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
  /** Decorative by default; pass a label to expose it to assistive tech. */
  label?: string;
}

const { name, size = 24, class: className = '', label } = Astro.props;

type IconDef = { body: string; filled?: boolean };

