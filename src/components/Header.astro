---
import { site } from '../data/site';
import { programs } from '../data/programs';
import Logo from './Logo.astro';
import Button from './Button.astro';
import Icon from './Icon.astro';

interface Props {
  /** Start transparent over a dark hero, solidify on scroll. */
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const nav = [
  { label: 'Courses', href: '/courses', mega: true },
  { label: 'About', href: '/about' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Contact', href: '/contact' },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => current === href.replace(/\/$/, '');
---
<header
  id="site-header"
  data-transparent={transparent ? '' : null}
  class="sticky top-0 z-50 w-full transition-[background-color,box-shadow,backdrop-filter] duration-300"
>
  <div class="container-x flex items-center justify-between gap-4 py-3.5">
    <a href="/" class="rounded-md" aria-label={`${site.name} — home`}>
      <Logo variant="dark" class="logo-dark h-10 sm:h-11" />
      <Logo variant="light" class="logo-light hidden h-10 sm:h-11" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
      {
        nav.map((item) =>
          item.mega ? (
            <div class="mega relative">
              <button
                type="button"
                class="nav-link mega-trigger inline-flex items-center gap-1 rounded-md px-3 py-2 text-[0.95rem] font-medium"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls="mega-programs"
              >
                {item.label}
                <Icon name="chevron-down" size={16} class="mega-caret transition-transform duration-200" />
              </button>

              <div
                id="mega-programs"
                class="mega-panel invisible absolute left-1/2 top-full z-10 w-[min(92vw,760px)] -translate-x-1/2 translate-y-2 pt-2 opacity-0 transition-all duration-200"
              >
                <div class="rounded-card border border-mist bg-paper p-3 shadow-lift">
                  <div class="grid gap-1 sm:grid-cols-2">
                    {programs.map((p) => (
                      <a
                        href={`/programs/${p.slug}`}
                        class="group flex items-start gap-3 rounded-btn p-3 transition-colors hover:bg-paper-2"
                      >
                        <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-btn bg-mist text-navy transition-colors group-hover:bg-navy group-hover:text-white">
                          <Icon name={p.icon} size={18} />
                        </span>
                        <span class="min-w-0">
                          <span class="block font-display text-[0.95rem] font-semibold text-navy">{p.name}</span>
                          <span class="block text-sm text-slate">{p.tagline}</span>
                        </span>
                      </a>
                    ))}
                  </div>
                  <div class="mt-1 grid grid-cols-2 gap-2">
                    <a
                      href="/courses"
                      class="flex items-center justify-between rounded-btn bg-navy px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-navy-800"
                    >
                      Browse all courses
                      <Icon name="arrow-right" size={16} />
                    </a>
                    <button
                      type="button"
                      data-open-demo
                      class="flex items-center justify-between rounded-btn bg-orange px-4 py-3 text-sm font-semibold text-navy transition-colors hover:bg-navy hover:text-white"
                    >
                      Book a free demo
                      <Icon name="arrow-right" size={16} />
                    </button>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="nav-link rounded-md px-3 py-2 text-[0.95rem] font-medium"
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>

    <div class="hidden lg:flex items-center gap-3">
      <a href={site.phoneHref} class="nav-link inline-flex items-center gap-2 rounded-md px-2 py-2 text-[0.92rem] font-semibold">
        <Icon name="phone" size={16} />
        <span>{site.phone}</span>
      </a>
      <Button href="/admissions" variant="primary" size="md">Book a free demo</Button>
    </div>

    <!-- Mobile toggle -->
    <button
      id="nav-toggle"
      type="button"
      class="nav-link lg:hidden grid h-11 w-11 place-items-center rounded-btn"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      aria-label="Open menu"
    >
      <Icon name="menu" size={24} />
    </button>
  </div>
</header>

<!-- Mobile drawer -->
<div
  id="mobile-drawer"
  class="fixed inset-0 z-[60] hidden lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Menu"
>
  <div class="drawer-backdrop absolute inset-0 bg-ink/55 opacity-0 transition-opacity duration-300"></div>
  <div
    class="drawer-panel absolute right-0 top-0 flex h-full w-[min(86vw,360px)] translate-x-full flex-col bg-paper shadow-lift transition-transform duration-300"
  >
    <div class="flex items-center justify-between border-b border-mist px-5 py-4">
      <Logo variant="dark" class="h-10" />
      <button id="nav-close" type="button" class="grid h-11 w-11 place-items-center rounded-btn text-navy hover:bg-paper-2" aria-label="Close menu">
        <Icon name="x" size={24} />
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto px-3 py-4" aria-label="Mobile">
      <a href="/courses" class="block rounded-btn px-4 py-3 text-base font-semibold text-navy hover:bg-paper-2">Courses</a>
      <div class="mb-2 grid grid-cols-1 gap-0.5 pl-2">
        {programs.map((p) => (
          <a href={`/programs/${p.slug}`} class="flex items-center gap-3 rounded-btn px-4 py-2.5 text-sm text-slate hover:bg-paper-2 hover:text-navy">
            <Icon name={p.icon} size={16} />
            {p.name}
          </a>
        ))}
      </div>
      {['About', 'Gallery', 'FAQ', 'Contact'].map((label) => (
        <a href={`/${label.toLowerCase()}`} class="block rounded-btn px-4 py-3 text-base font-semibold text-navy hover:bg-paper-2">
          {label}
        </a>
      ))}
    </nav>

    <div class="border-t border-mist px-5 py-4 space-y-3">
      <a href={site.phoneHref} class="flex items-center justify-center gap-2 rounded-btn px-4 py-3 font-semibold text-navy ring-1 ring-slate/35">
        <Icon name="phone" size={18} /> {site.phone}
      </a>
      <Button href="/admissions" variant="primary" size="lg" class="w-full">Book a free demo</Button>
    </div>
  </div>
</div>

<style>
  /* Solid state: frosted white + navy text + subtle shadow. */
  #site-header.is-solid {
    background-color: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    box-shadow: 0 1px 0 rgba(112, 134, 178, 0.18), var(--shadow-soft);
  }
  /* Interior pages (no [data-transparent]) keep a solid base from the start. */
  #site-header:not([data-transparent]) {
    background-color: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
  }

  .nav-link {
    color: var(--navy);
    transition: color 0.2s, background-color 0.2s;
  }
  .nav-link:hover { color: var(--orange); }
  .nav-link[aria-current='page'] { color: var(--orange); }

  /* Transparent-over-hero state: white text + light logo. */
  #site-header[data-transparent]:not(.is-solid) .nav-link { color: #fff; }
  #site-header[data-transparent]:not(.is-solid) .nav-link:hover { color: var(--mist); }
  /* :global() so these reach the <img> rendered by the child Logo component. */
  #site-header[data-transparent]:not(.is-solid) :global(.logo-dark) { display: none; }
  #site-header[data-transparent]:not(.is-solid) :global(.logo-light) { display: inline-block; }

  /* Mega-menu open state (hover, focus-within, or JS class). */
  .mega:hover .mega-panel,
  .mega:focus-within .mega-panel,
  .mega.is-open .mega-panel {
    visibility: visible;
    opacity: 1;
    transform: translate(-50%, 0);
  }
  .mega:hover .mega-caret,
  .mega.is-open .mega-caret { transform: rotate(180deg); }
</style>

<script>
  // --- Sticky solidify on scroll ---
  const header = document.getElementById('site-header')!;
  const onScroll = () => header.classList.toggle('is-solid', window.scrollY > 24);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // --- Desktop mega-menu: keep aria-expanded in sync; Escape closes ---
  const mega = document.querySelector<HTMLElement>('.mega');
  const trigger = mega?.querySelector<HTMLButtonElement>('.mega-trigger');
  if (mega && trigger) {
    const setOpen = (open: boolean) => {
      mega.classList.toggle('is-open', open);
      trigger.setAttribute('aria-expanded', String(open));
    };
    trigger.addEventListener('click', () => setOpen(!mega.classList.contains('is-open')));
    mega.addEventListener('focusin', () => trigger.setAttribute('aria-expanded', 'true'));
    mega.addEventListener('focusout', (e) => {
      if (!mega.contains(e.relatedTarget as Node)) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { setOpen(false); trigger.blur(); }
    });
  }

  // --- Mobile drawer ---
  const drawer = document.getElementById('mobile-drawer')!;
  const backdrop = drawer.querySelector<HTMLElement>('.drawer-backdrop')!;
  const panel = drawer.querySelector<HTMLElement>('.drawer-panel')!;
  const toggle = document.getElementById('nav-toggle')!;
  const closeBtn = document.getElementById('nav-close')!;
  let lastFocused: HTMLElement | null = null;

  const openDrawer = () => {
    lastFocused = document.activeElement as HTMLElement;
    drawer.classList.remove('hidden');
    requestAnimationFrame(() => {
      backdrop.classList.remove('opacity-0');
      panel.classList.remove('translate-x-full');
    });
    document.body.style.overflow = 'hidden';
    toggle.setAttribute('aria-expanded', 'true');
    closeBtn.focus();
  };
  const closeDrawer = () => {
    backdrop.classList.add('opacity-0');
    panel.classList.add('translate-x-full');
    document.body.style.overflow = '';
    toggle.setAttribute('aria-expanded', 'false');
    window.setTimeout(() => drawer.classList.add('hidden'), 300);
    lastFocused?.focus();
  };

  toggle.addEventListener('click', openDrawer);
  closeBtn.addEventListener('click', closeDrawer);
  backdrop.addEventListener('click', closeDrawer);
  drawer.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });
  // Close after navigating to a hash/section on mobile.
  drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeDrawer));
</script>
