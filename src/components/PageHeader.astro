---
/** Interior-page hero. Includes top padding so content clears the fixed header. */
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
}
const { eyebrow, title, intro } = Astro.props;
---
<section class="relative overflow-hidden bg-navy text-white">
  <div class="grid-motif pointer-events-none absolute inset-0 opacity-25"></div>
  <div class="pointer-events-none absolute -right-24 top-0 h-72 w-72 rounded-full bg-orange/10 blur-3xl"></div>
  <div class="container-x relative max-w-3xl pb-14 pt-32 md:pb-20 md:pt-40">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="mt-3 font-display text-display-xl text-white">{title}</h1>
    {intro && <p class="mt-5 max-w-2xl text-lg leading-relaxed text-mist">{intro}</p>}
    <slot />
  </div>
</section>
