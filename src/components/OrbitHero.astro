---
import { programs } from '../data/programs';
import Icon from './Icon.astro';

/**
 * THE signature (§4). Six program nodes rest on elliptical orbits around a
 * gravitational core carrying the wordmark / orange "A" triangle.
 *
 * Motion is deliberate and singular:
 *  - On load, nodes FALL toward their orbit and settle (gravitational easing:
 *    ease-in fall + slight overshoot/settle). Core scales in.
 *  - A faint dashed ring sweeps slowly; the core breathes.
 *  - Gentle scroll parallax (added by index.astro's hero script).
 * Nodes are STATIC tap targets — they never move away from the cursor — so they
 * stay tappable and route to their program. Under prefers-reduced-motion the
 * global stylesheet freezes all of it and the resting composition ships as-is.
 *
 * Coordinates live in a 600×600 viewBox space; the SVG and the percentage-placed
 * nodes scale together, so it's fully responsive down to ~300px with no JS.
 */

// Resting positions on the three ellipses, ordered to match programs.ts.
const positions = [
  { left: '14%', top: '40.6%' }, // Foundation   — outer
  { left: '75.9%', top: '38%' },    // Test Prep    — mid
  { left: '85.5%', top: '58.5%' }, // JEE          — outer
  { left: '68.9%', top: '52.2%' },  // NEET         — inner
  { left: '29.6%', top: '66.1%' },  // Olympiads    — mid
  { left: '34.4%', top: '75.5%' },  // Subject      — outer
];
const nodes = programs.map((p, i) => ({ ...p, ...positions[i % positions.length] }));
---
<div class="orbit-system relative mx-auto aspect-square w-full max-w-[34rem]" aria-hidden="false">
  <!-- Orbit rings + scientific grid (decorative; encodes the 6 programs in orbit) -->
  <svg
    class="orbit-rings absolute inset-0 h-full w-full"
    viewBox="0 0 600 600"
    fill="none"
    aria-hidden="true"
  >
    <defs>
      <radialGradient id="coreGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--orange)" stop-opacity="0.18" />
        <stop offset="60%" stop-color="var(--orange)" stop-opacity="0.04" />
        <stop offset="100%" stop-color="var(--orange)" stop-opacity="0" />
      </radialGradient>
    </defs>
    <circle cx="300" cy="300" r="230" fill="url(#coreGlow)" />
    <ellipse cx="300" cy="300" rx="250" ry="165" stroke="var(--slate)" stroke-opacity="0.32" />
    <ellipse cx="300" cy="300" rx="190" ry="126" stroke="var(--slate)" stroke-opacity="0.4" />
    <ellipse cx="300" cy="300" rx="115" ry="75" stroke="var(--slate)" stroke-opacity="0.5" />
    <!-- slow sweeping dashed ring = continuous orbital motion, kept faint -->
    <ellipse
      class="orbit-sweep"
      cx="300"
      cy="300"
      rx="190"
      ry="126"
      stroke="var(--orange)"
      stroke-opacity="0.5"
      stroke-width="1.5"
      stroke-dasharray="2 26"
      stroke-linecap="round"
    />
  </svg>

  <!-- Gravitational core: orange "A" triangle + wordmark -->
  <div class="orbit-core absolute left-1/2 top-1/2 grid aspect-square w-[26%] -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full bg-navy text-white shadow-lift ring-1 ring-white/10">
    <div class="flex flex-col items-center gap-1">
      <svg width="34" height="34" viewBox="0 0 26 26" fill="none" aria-hidden="true">
        <path d="M13 4 21 21H5L13 4Z" fill="var(--orange)" />
      </svg>
      <span class="font-mono text-[0.55rem] uppercase tracking-[0.28em] text-mist">Gravity</span>
    </div>
  </div>

  <!-- Program nodes (static, tappable) -->
  {
    nodes.map((p, i) => (
      <a
        href={`/programs/${p.slug}`}
        class="orbit-node group absolute flex -translate-x-1/2 -translate-y-1/2 flex-col items-center gap-1.5"
        style={`left:${p.left};top:${p.top};--i:${i}`}
        aria-label={`${p.name} — ${p.tagline}`}
      >
        <span class="grid h-[clamp(2.6rem,9vw,3.4rem)] w-[clamp(2.6rem,9vw,3.4rem)] place-items-center rounded-full border border-mist bg-paper text-navy shadow-soft transition-all duration-300 ease-fall group-hover:-translate-y-0.5 group-hover:border-orange group-hover:bg-orange group-hover:text-navy group-focus-visible:border-orange">
          <Icon name={p.icon} size={22} />
        </span>
        <span class="max-w-[5.5rem] text-center font-display text-[0.68rem] font-semibold leading-tight text-navy">
          {p.name.replace(/\s*\(.*\)/, '')}
        </span>
      </a>
    ))
  }
</div>

<style>
  /* Gravitational entrance: fall inward, slight settle. fill: both so the
     resting style is also the final keyframe — reduced motion shows it instantly. */
  @keyframes node-fall {
    from {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.4);
    }
    70% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.08);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
  }
  @keyframes core-in {
    from { opacity: 0; transform: translate(-50%, -50%) scale(0.6); }
    to { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  }
  @keyframes sweep {
    to { transform: rotate(360deg); transform-origin: 300px 300px; }
  }
  @keyframes breathe {
    0%, 100% { box-shadow: var(--shadow-lift); }
    50% { box-shadow: var(--shadow-lift), 0 0 0 8px rgba(253, 94, 3, 0.06); }
  }

  .orbit-node {
    animation: node-fall 0.9s var(--ease-gravity) both;
    animation-delay: calc(0.15s + var(--i) * 0.12s);
  }
  .orbit-core {
    animation: breathe 6s ease-in-out infinite, core-in 0.8s var(--ease-gravity) both;
  }
  .orbit-sweep {
    animation: sweep 36s linear infinite;
  }

  /* Pause the sweep while a user is interacting, so motion never distracts. */
  .orbit-system:hover .orbit-sweep,
  .orbit-system:focus-within .orbit-sweep { animation-play-state: paused; }
</style>
